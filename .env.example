# ===== 数据库 =====
DATABASE_URL="postgresql://eval:eval_pwd@localhost:5432/teaching_eval?schema=public"
POSTGRES_PASSWORD="eval_pwd"          # 生产请改强口令

# ===== Redis（会话、实时聚合、队列）=====
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD="redis_pwd_change_me"  # 生产请改强口令

# ===== JWT 认证（生产必填，缺失/默认值时 api 拒绝启动）=====
# 生成：openssl rand -hex 32
JWT_SECRET=""
JWT_EXPIRES_IN="8h"
JWT_REFRESH_SECRET=""
JWT_REFRESH_EXPIRES_IN="7d"

# ===== 对象存储 MinIO =====
MINIO_ENDPOINT="localhost"
MINIO_PORT=9000
MINIO_ROOT_USER="minioadmin"          # 生产请改
MINIO_ROOT_PASSWORD="minioadmin"      # 生产请改
MINIO_BUCKET="teaching-eval"
MINIO_USE_SSL=false

# ===== 应用 =====
API_PORT=4000
WEB_PORT=3000
# 浏览器访问 API 的地址（构建期注入前端）
PUBLIC_API_URL="http://localhost:4000/api/v1"
NEXT_PUBLIC_API_BASE_URL="http://localhost:4000/api/v1"
# 可选：限定 CORS 来源（多个用逗号），如 http://172.17.23.37:3000
WEB_ORIGIN=""

# ===== 初始管理员（首次 seed）=====
SEED_ADMIN_ACCOUNT="admin"
SEED_ADMIN_PASSWORD="Admin@123"
